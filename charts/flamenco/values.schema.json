{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1
    },
    "flamenco": {
      "type": "object",
      "properties": {
        "managerName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "blenderPath": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "blenderArgs": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicas": {
          "type": "integer",
          "minimum": 0,
          "maximum": 50
        },
        "resources": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": ["string", "number"],
                  "pattern": "^[0-9]+m?$"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi)$"
                }
              }
            },
            "limits": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": ["string", "number"],
                  "pattern": "^[0-9]+m?$"
                },
                "memory": {
                  "type": "string",
                  "pattern": "^[0-9]+(Mi|Gi)$"
                }
              }
            }
          }
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hostname": {
          "type": "string",
          "maxLength": 253
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "manager": {
          "type": "object",
          "properties": {
            "accessMode": {
              "type": "string",
              "enum": ["ReadWriteOnce", "ReadWriteMany"]
            },
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(Mi|Gi)$"
            }
          }
        },
        "shared": {
          "type": "object",
          "properties": {
            "accessMode": {
              "type": "string",
              "enum": ["ReadWriteOnce", "ReadWriteMany"]
            },
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(Mi|Gi)$"
            }
          }
        }
      }
    }
  }
}
